---
interface Feature {
    icon: string;
    title: string;
    description: string;
}

interface LogLine {
    time: string;
    level: "SYSTEM" | "INFO" | "WARN" | "SUCCESS" | "ERROR";
    message: string;
}

interface Props {
    title?: string;
    description?: string;
    features?: Feature[];
    consolePath?: string;
    consoleLogs?: LogLine[];
    consoleCommand?: string;
    glowTo?: string; // color del glow right (ej: "purple-600", "blue-600")
}

const {
    title = "El control en tus manos",
    description = "Gestiona cada aspecto de tu servidor con un par de clics.",
    features = [],
    consolePath = "root@vhost-node:~/server",
    consoleLogs = [],
    consoleCommand = "",
    glowTo = "purple-600",
} = Astro.props;

const levelColors: Record<string, string> = {
    SYSTEM: "text-blue-400",
    INFO: "",
    WARN: "text-yellow-500",
    SUCCESS: "text-green-400 font-bold",
    ERROR: "text-red-400 font-bold",
};
---

<section class="py-20 px-4 bg-[#101010] border-t border-white/5">
    <div
        class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
    >
        <!-- Texto + features (izquierda) -->
        <div class="space-y-8 order-2 lg:order-1">
            <div>
                <h2
                    class="text-3xl md:text-4xl font-poppins font-bold text-white mb-4"
                >
                    {title}
                </h2>
                <p class="text-gray-400 text-lg">{description}</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {
                    features.map((f) => (
                        <div class="bg-[#1a1a1a] rounded-xl p-4 hover:bg-[#222222] transition-all duration-300 group">
                            <div class="w-10 h-10 rounded-lg bg-[#fc7c04]/10 flex items-center justify-center text-[#fc7c04] mb-3 group-hover:bg-[#fc7c04]/20 transition-colors">
                                <i class={`fas ${f.icon} text-lg`} />
                            </div>
                            <h3 class="text-white font-bold text-sm mb-1">
                                {f.title}
                            </h3>
                            <p class="text-xs text-gray-500 leading-relaxed">
                                {f.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Terminal (derecha) -->
        <div class="relative group order-1 lg:order-2">
            <div
                class={`absolute -inset-1 bg-gradient-to-r from-[#fc7c04] to-${glowTo} rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-1000`}
            >
            </div>

            <div
                class="relative rounded-2xl overflow-hidden border border-white/10 bg-[#0F0F0F] shadow-2xl h-[370px] flex flex-col font-mono text-xs md:text-sm"
            >
                <!-- Barra título -->
                <div
                    class="h-9 bg-[#1a1a1a] border-b border-white/5 flex items-center px-4 justify-between select-none"
                >
                    <div class="flex gap-2">
                        <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-500/80">
                        </div>
                        <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
                    </div>
                    <div
                        class="text-gray-500 text-xs font-semibold tracking-wide"
                    >
                        {consolePath}
                    </div>
                    <div class="w-10"></div>
                </div>

                <!-- Logs -->
                <div
                    class="flex-grow p-4 overflow-hidden text-gray-300 space-y-1 opacity-90"
                >
                    {
                        consoleLogs.map((log) => (
                            <div class={levelColors[log.level] ?? ""}>
                                <span class="text-gray-500">[{log.time}]</span>{" "}
                                <span
                                    set:html={`[${log.level}]: ${log.message}`}
                                />
                            </div>
                        ))
                    }
                    <div class="animate-pulse text-[#fc7c04] mt-1">_</div>
                </div>

                <!-- Barra comando -->
                <div
                    class="h-10 bg-[#151515] border-t border-white/5 flex items-center px-4 text-gray-400"
                >
                    <span class="text-[#fc7c04] mr-2">➜</span>
                    <span>{consoleCommand}</span>
                </div>
            </div>
        </div>
    </div>
</section>
