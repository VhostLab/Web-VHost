---
import MainLayout from "@layouts/MainLayout.astro";
import "@/styles/global.css";
import HeroContacto from "@components/sections/pages/HeroContacto.astro";
import SupportOptions from "@components/ui/SupportOptions.astro";
import FAQSection from "@components/sections/pages/FAQSection.astro";
const faqs = [
  {
    question: "¿Qué métodos de pago aceptan?",
    answer: "Aceptamos tarjetas de crédito, PayPal y bizum.",
  },
  {
    question: "¿Cuánto tarda en llegar mi servidor?",
    answer: "La instalación es instantánea tras el pago.",
  },
  {
    question: "¿Por qué debería elegir Vhost?",
    answer: "Ofrecemos hardware premium y soporte 24/7 a precios competitivos.",
  },
  {
    question: "¿Se puede instalar mods o plugins en los servidores?",
    answer:
      "Claro, tienes acceso FTP para subir todos los mods/plugins que quieras.",
  },
  {
    question: "¿Los servidores funcionan con Minecraft Bedrock?",
    answer: "Sí, soportamos tanto Java Edition como Bedrock Edition.",
  },
  {
    question: "¿Puedo subir mi propio mundo al servidor?",
    answer: "Puedes subir tu mundo directamente desde la sección Archivos.",
  },
  {
    question: "¿Actualmente estoy con otro hosting, puedo migrarme a Vhost?",
    answer: "Sí, ofrecemos migración gratuita de tu servidor actual.",
  },
  {
    question: "¿Qué plan debería elegir?",
    answer:
      "Depende de tu uso; revisa las características de cada plan para decidir.",
  },
  {
    question: "¿Qué garantía de disponibilidad ofrecen?",
    answer:
      "Garantizamos un 99.9% de uptime con monitoreo 24/7 y protección DDoS.",
  },
  {
    question: "¿Realizan copias de seguridad automáticas?",
    answer:
      "Ofrecemos backups diarios automáticos opcionales para asegurar tus datos.",
  },
];
---

<MainLayout
  title="Soporte"
  description="¿Tienes dudas o necesitas ayuda? Contacta con el equipo de soporte de Vhost a través de Discord, ticket, email o redes sociales. Estamos aquí para ayudarte 24/7."
  image="https://vhost.tech/SEO/vhost-preview.png"
  url="https://vhost.tech/soporte"
>
  <HeroContacto />

  <SupportOptions backgroundClass="bg-primary text-white" />

  <section class="bg-[#0b0b0b] text-white py-24 px-6">
    <div
      class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 items-center gap-12"
    >
      <!-- Texto a la izquierda -->
      <div>
        <h2 class="text-4xl md:text-5xl font-bold font-poppins mb-4">
          Un equipo que entiende tus necesidades
        </h2>
        <p class="text-gray-400 text-lg font-poppins max-w-xl">
          Somos jugadores como tú, y hemos pasado por los mismos errores.
          Nuestro soporte está enfocado en ayudarte de forma rápida, real y
          cercana. Habla con alguien que realmente entiende lo que haces.
        </p>
      </div>

      <!-- Imagen a la derecha -->
      <div class="flex justify-center md:justify-end">
        <img
          src="/images/VhostNPC.webp"
          alt="Equipo de soporte"
          class="w-72 md:w-[22rem] object-contain pointer-events-none"
        />
      </div>
    </div>
  </section>

  <script is:inline>
    document
      .querySelector('a[href="#support-options"]')
      ?.addEventListener("click", (e) => {
        e.preventDefault();
        const section = document.getElementById("support-options");
        if (section) {
          section.scrollIntoView({ behavior: "smooth" });
        }
      });
  </script>
  <FAQSection
    items={faqs}
    inviteLink="https://discord.gg/Ykr85wevrj"
    backgroundClass="bg-primary"
  />
</MainLayout>
