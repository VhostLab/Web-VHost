---
import MainLayout from "@layouts/MainLayout.astro";
import "@/styles/global.css";
import HeroTienda from "@components/sections/pages/HeroTienda.astro";
import FAQSection from "@components/sections/pages/FAQSection.astro";
import Card from "@components/products/card.astro";
import ConsoleSection from "@components/sections/servers/ConsoleSection.astro";
import ServerMap from "@components/sections/servers/ServerMap.astro";
import SupportBanner from "@components/ui/SupportBanner.astro";

const tsPlans = [
  {
    type: "TeamSpeak Pro",
    ram: "32 SLOTS",
    img: "/images/tienda/teamspeak3/plan/ts3.webp",
    price: "0,99€ /mes",
    url: "https://billing.vhost.tech/products/teamspeak-3/teamspeak-3",
  },
];

const tsFeatures = [
  { icon: "fas fa-users mr-2.5", text: "<strong>32</strong> Slots" },
  {
    icon: "fas fa-shield-alt mr-3.5",
    text: "Protección <strong>Anti-DDoS</strong>",
  },
  { icon: "fas fa-server mr-3.5", text: "<strong>99,9%</strong> Uptime" },
  {
    icon: "fas fa-volume-up mr-3.5",
    text: "Calidad de <strong>Audio HD</strong>",
  },
];

const faqs = [
  {
    question: "¿Qué métodos de pago aceptan?",
    answer: "Aceptamos tarjetas de crédito, PayPal y Bizum.",
  },
  {
    question: "¿Cuánto tarda en estar disponible mi servidor de TeamSpeak?",
    answer:
      "La instalación es instantánea tras el pago. Recibirás los datos de acceso al momento.",
  },
  {
    question: "¿Por qué debería elegir Vhost para mi servidor de TeamSpeak?",
    answer:
      "Ofrecemos máxima calidad de audio, soporte técnico 24/7 y una infraestructura segura y estable.",
  },
  {
    question: "¿Puedo gestionar los permisos y canales de mi TeamSpeak?",
    answer:
      "Sí, tienes acceso completo al panel de administración para personalizar tu servidor a tu gusto.",
  },
  {
    question: "¿Cuántos usuarios soporta el servidor?",
    answer: "El número de slots es de 32.",
  },
  {
    question: "¿Puedo migrar mi servidor de otro proveedor?",
    answer:
      "Sí, ofrecemos migración gratuita para que no pierdas tu configuración ni historial.",
  },
  {
    question: "¿Qué garantía de disponibilidad ofrecen?",
    answer:
      "Garantizamos un 99.9% de uptime, con monitoreo 24/7 y protección avanzada contra ataques DDoS.",
  },
  {
    question: "¿Realizan copias de seguridad automáticas?",
    answer:
      "Ofrecemos backups diarios automáticos opcionales para proteger tu configuración y canales.",
  },
];
---

<MainLayout
  title="TeamSpeak 3 Hosting"
  description="Contrata tu servidor de TeamSpeak 3 en Vhost: instalación instantánea, soporte 24/7, protección anti-DDoS y calidad de audio HD."
  image="https://vhost.tech/SEO/vhost-preview.png"
  url="https://vhost.tech/tienda/teamspeak3"
>
  <HeroTienda
    titulo="TeamSpeak Hosting"
    imagenFondo="/images/tienda/teamspeak3/ts-bg.webp"
  />

  <!-- Sección plan -->
  <section class="relative bg-[#0b0b0b] text-white py-12 px-4">
    <div class="text-center mt-12 mb-6">
      <h2 class="text-3xl font-poppins font-semibold text-white">
        Nuestro plan TeamSpeak
      </h2>
      <p class="text-gray-300 font-poppins mt-1">
        Un solo plan, todo incluido, sin complicaciones.
      </p>
    </div>
    <div
      id="budget-section"
      class="transition-opacity duration-200 ease-in-out opacity-100"
    >
      <Card products={tsPlans} featuresList={tsFeatures} />
    </div>
  </section>

  <!-- Sección características -->
  <section class="bg-[#0b0b0b] py-16 px-4 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-poppins font-bold text-white mb-4">
          ¿Por qué elegir TeamSpeak con Vhost?
        </h2>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          Comunicación de calidad profesional para tu equipo, clan o comunidad.
          Sin retrasos, sin cortes, sin compromisos.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1 -->
        <div
          class="bg-[#111111] border border-white/10 rounded-xl p-6 hover:border-[#fc7c04]/40 transition-all duration-300 group"
        >
          <div
            class="w-12 h-12 rounded-lg bg-blue-900/30 text-blue-400 flex items-center justify-center mb-4 group-hover:bg-blue-800/50 group-hover:text-blue-300 transition-all duration-300"
          >
            <i class="fas fa-microphone text-xl"></i>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">Audio HD</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Codec Opus de última generación. Voz cristalina sin compresión y con
            latencia mínima.
          </p>
        </div>

        <!-- Card 2 -->
        <div
          class="bg-[#111111] border border-white/10 rounded-xl p-6 hover:border-[#fc7c04]/40 transition-all duration-300 group"
        >
          <div
            class="w-12 h-12 rounded-lg bg-green-900/30 text-green-400 flex items-center justify-center mb-4 group-hover:bg-green-800/50 group-hover:text-green-300 transition-all duration-300"
          >
            <i class="fas fa-shield-alt text-xl"></i>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">Anti-DDoS</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Protección avanzada ante ataques DDoS incluida en todos los planes.
            Tu servidor siempre disponible.
          </p>
        </div>

        <!-- Card 3 -->
        <div
          class="bg-[#111111] border border-white/10 rounded-xl p-6 hover:border-[#fc7c04]/40 transition-all duration-300 group"
        >
          <div
            class="w-12 h-12 rounded-lg bg-purple-900/30 text-purple-400 flex items-center justify-center mb-4 group-hover:bg-purple-800/50 group-hover:text-purple-300 transition-all duration-300"
          >
            <i class="fas fa-lock text-xl"></i>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">Cifrado E2E</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Todas las comunicaciones cifradas de extremo a extremo. Tus
            conversaciones son privadas.
          </p>
        </div>

        <!-- Card 4 -->
        <div
          class="bg-[#111111] border border-white/10 rounded-xl p-6 hover:border-[#fc7c04]/40 transition-all duration-300 group"
        >
          <div
            class="w-12 h-12 rounded-lg bg-orange-900/30 text-[#fc7c04] flex items-center justify-center mb-4 group-hover:bg-orange-800/50 group-hover:text-orange-300 transition-all duration-300"
          >
            <i class="fas fa-bolt text-xl"></i>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">
            Activación Instantánea
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Tu servidor listo en segundos tras el pago. Sin esperas ni trámites
            manuales.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección terminal / panel de control -->
  <ConsoleSection
    title="Panel de control en tus manos"
    description="Gestiona tu servidor de TeamSpeak 3 desde cualquier lugar. Crea canales, asigna permisos y monitoriza conexiones en tiempo real."
    glowTo="blue-600"
    consolePath="root@vhost-ts3:~/teamspeak3-server"
    consoleCommand="clientkick clid=2 reasonid=5 reasonmsg=AFK"
    features={[
      {
        icon: "fa-layer-group",
        title: "Gestión de Canales",
        description:
          "Crea canales ilimitados, añade contraseñas y organiza tu comunidad como quieras.",
      },
      {
        icon: "fa-user-shield",
        title: "Sistema de Permisos",
        description:
          "Asigna roles y permisos granulares a cada usuario o grupo de tu servidor.",
      },
      {
        icon: "fa-cloud-upload-alt",
        title: "Backups Automáticos",
        description:
          "Tu configuración siempre a salvo. Crea y restaura copias de seguridad con un clic.",
      },
      {
        icon: "fa-chart-bar",
        title: "Estadísticas en Vivo",
        description:
          "Monitoriza ancho de banda, latencia y conexiones activas en tiempo real.",
      },
    ]}
    consoleLogs={[
      {
        time: "09:00:01",
        level: "SYSTEM",
        message: "Booting TeamSpeak 3 Server v3.13.7...",
      },
      {
        time: "09:00:01",
        level: "INFO",
        message:
          'Loading config file server.ini... <span class="text-green-500">OK</span>',
      },
      {
        time: "09:00:02",
        level: "INFO",
        message:
          'Anti-DDoS protection <span class="text-green-500">enabled</span>.',
      },
      {
        time: "09:00:02",
        level: "INFO",
        message:
          'Codec: Opus Voice / Opus Music — HD quality <span class="text-green-500">active</span>.',
      },
      {
        time: "09:00:03",
        level: "INFO",
        message:
          'Listening on UDP port <span class="text-yellow-400">9987</span>...',
      },
      {
        time: "09:00:04",
        level: "INFO",
        message:
          'Max slots: <span class="text-yellow-400">32</span> — Encryption: <span class="text-green-500">end-to-end</span>.',
      },
      {
        time: "09:00:06",
        level: "SUCCESS",
        message: "Server is UP — 2/32 slots in use.",
      },
    ]}
  />

  <!-- Mapa de servidores -->
  <ServerMap />

  <!-- Banner soporte -->
  <SupportBanner />

  <FAQSection
    items={faqs}
    inviteLink="https://discord.gg/Ykr85wevrj"
    backgroundClass="bg-[#0b0b0b]"
  />
</MainLayout>
