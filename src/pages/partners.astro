---
import MainLayout from "@layouts/MainLayout.astro";
import "@/styles/global.css";
import HeroPartners from "@components/partners/HeroPartners.astro";
import HistorialCreadores from "@components/partners/HistorialCreadores.astro";
import VentajasPartners from "@components/partners/VentajasPartners.astro";
import HistorialEventos from "@components/partners/HistorialEventos.astro";
import SupportOptions from "@components/ui/SupportOptions.astro";
---

<MainLayout
  title="Partners"
  description="¿Eres creador de contenido, club o comunidad? Únete a nuestro programa de partners, colabora con Vhost y gana comisiones trayendo nuevos clientes. ¡Crecemos juntos!"
  image="https://vhost.tech/SEO/vhost-preview.png"
  url="https://vhost.tech/partners"
>
  <HeroPartners />

  <VentajasPartners />
  <HistorialEventos />
  <HistorialCreadores />

  <SupportOptions
    title="Nuestras opciones de contacto"
    backgroundClass="bg-[#0b0b0b] text-white"
  />
</MainLayout>
